{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-destroy",
    "dialog:default",
    "store:default"
  ]
}
