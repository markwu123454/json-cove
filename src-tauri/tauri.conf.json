{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JSON Cove",
  "version": "0.1.0",
  "identifier": "com.markwu.jsoncove",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JSON Cove",
        "width": 1000,
        "height": 680,
        "minWidth": 560,
        "minHeight": 400,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "A tiny, fast JSON viewer and editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON document",
        "role": "Editor"
      }
    ]
  }
}
