{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JSON Cove",
  "version": "0.1.0",
  "identifier": "com.markwu.jsoncove",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JSON Cove",
        "width": 1000,
        "height": 680,
        "minWidth": 560,
        "minHeight": 400,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/markwu123454/json-cove/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4OTkwRjA0NEE0REYxM0UKUldRKzhVMUtCQStaV0FvMHh2YjlPNUJRSnJnL0h0VGx4WVlQazZJZzVUNTdSOGFMZkJwUjNGaG4K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "createUpdaterArtifacts": true,
    "resources": ["fileicons/*.ico"],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    },
    "shortDescription": "A tiny, fast JSON viewer and editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON document",
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "ext": ["jsonl", "ndjson", "ldjson"],
        "name": "JSON Lines File",
        "description": "JSON Lines / newline-delimited JSON document",
        "mimeType": "application/x-ndjson",
        "role": "Editor"
      }
    ]
  }
}
